      "end": 19.51
    },
    {
      "id": 7,
      "texte": "Un bras court agit comme un levier compact.",
      "start": 20.2,
      "end": 22.2
    },
    {
      "id": 8,
      "texte": "Il accélère beaucoup plus vite vers sa cible.",
